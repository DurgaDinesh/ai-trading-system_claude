# ═══════════════════════════════════════════════════════════════════════════════
# ENVIRONMENT VARIABLES — copy to .env and fill in real values
# NEVER commit .env to version control
# ═══════════════════════════════════════════════════════════════════════════════

# ── Zerodha Kite Connect ───────────────────────────────────────────────────────
KITE_API_KEY=your_api_key_here
KITE_API_SECRET=your_api_secret_here
KITE_USER_ID=xxxx

# ── Anthropic (Claude AI) ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── News API (newsapi.org) ─────────────────────────────────────────────────────
NEWS_API_KEY=your_newsapi_key_here

# ── Telegram Bot ──────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
TELEGRAM_ADMIN_CHAT_ID=your_personal_chat_id_here

# ── Dashboard Security ─────────────────────────────────────────────────────────
DASHBOARD_SECRET_KEY=generate_a_long_random_string_here
DASHBOARD_USERNAME=admin

# ── Vault Encryption ──────────────────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
VAULT_ENCRYPTION_KEY=your_32_byte_base64_fernet_key_here

# ── PIN (stored as bcrypt hash — never store plain PIN) ───────────────────────
# Generate with: python -c "import bcrypt; print(bcrypt.hashpw(b'your6digitpin', bcrypt.gensalt()).decode())"
TRADE_PIN_HASH=your_bcrypt_hash_here

# ── Database (production PostgreSQL) ──────────────────────────────────────────
# DATABASE_URL=postgresql://user:password@localhost:5432/algotrading

# ── IP Whitelist (comma-separated) ────────────────────────────────────────────
ALLOWED_IPS=127.0.0.1,your.server.ip.here
